                return BadRequest(ex.ToString());
            }

        }


        [HttpGet]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [Route("{userid}/{orgid}/{ID}")]
        public async Task<IActionResult> GetResourceUtil(string userid, string orgid, string ID = null)
        {
            try
            {
                logger.LogInformation("\nGET request triggered for GetResourceUtil\n");

                if (ID != null)
                {
                    var obj = db.Devices.FirstOrDefault(d => d.Id.ToString() == ID && d.OrgID.ToString() == orgid);
                    if (obj == null)
                    {
                        return NotFound("No Device Found");
                    }
                    var objectID = obj.ObjectID.ToString();
                    var asset = db.EASpecifications.FirstOrDefault(u => u.ObjectID == objectID && u.OrgID == orgid);
                    if (asset == null)
                    {
                        return NotFound();
                    }
                    var systemId = asset.ID;
                    var details = await db.ResourceUtils.Where(u => u.SystemId == systemId).ToListAsync();
                    List<ITAMEAResourceUtilDTO> result = new List<ITAMEAResourceUtilDTO>();
                    foreach (var detail in details)
                    {
                        var model = new ITAMEAResourceUtilDTO()
                        {
                            BytesReceived = detail.BytesReceived,
                            BytesSent = detail.BytesSent,
                            CPUUsage = detail.CPUUsage,
                            PhysicalDiskUsage = detail.PhysicalDiskUsage,
                            MemoryUsage = detail.MemoryUsage,
                            GPUUsage = detail.GPUUsage
                        };
                        result.Add(model);
                    }
                    return Ok(result);
                }
                return NotFound();
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for GetResourceUtil for user: " + userid);
                return BadRequest(ex.ToString());
            }

        }


        [HttpGet]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [Route("{userid}/{orgid}/{ID}")]
        public async Task<IActionResult> GetEA_DiskDetails(string userid, string orgid, string ID = null)
        {
            try
            {
                logger.LogInformation("\nGET request triggered for GetEA_DiskDetails\n");

                if (ID != null)
                {
                    var obj = db.Devices.FirstOrDefault(d => d.Id.ToString() == ID && d.OrgID.ToString() == orgid);
                    if (obj == null)
                    {
                        return NotFound("No Device Found");
                    }
                    var objectID = obj.ObjectID.ToString();
                    var asset = db.EASpecifications.FirstOrDefault(u => u.ObjectID == objectID && u.OrgID == orgid);
                    if (asset == null)
                    {
                        return NotFound();
                    }
                    var systemId = asset.ID;
                    var diskDetails = await db.DiskDetails.Where(u => u.SystemId == systemId).Include(u => u.PartitionDetails).ToListAsync();
                    List<ITAMEADiskDetailDTO> result = new List<ITAMEADiskDetailDTO>();
                    foreach (DiskDetail diskDetail in diskDetails)
                    {
                        var model = new ITAMEADiskDetailDTO()
                        {
                            Capacity = diskDetail.Capacity,
                            DeviceID = diskDetail.DeviceID,
                            Index = diskDetail.Index,
                            Model = diskDetail.Model,
                            Manufacturer = diskDetail.Manufacturer,
                            MediaType = diskDetail.MediaType,
                            SerialNumber = diskDetail.SerialNumber,
                            FirmwareRevision = diskDetail.FirmwareRevision,
                            Partitions = diskDetail.Partitions,
                            InterfaceType = diskDetail.InterfaceType,
                            Status = diskDetail.Status,
                            InstallDate = diskDetail.InstallDate,
                            PartitionDetails = diskDetail.PartitionDetails.Select(partition => new PartitionDetailDTO
                            {
                                DeviceID = partition.DeviceID,
                                Index = partition.Index,
                                DiskIndex = partition.DiskIndex,
                                Bootable = partition.Bootable,
                                BootPartition = partition.BootPartition,
                                PrimaryPartition = partition.PrimaryPartition,
                                Size = partition.Size,
                                State = partition.State,
                                DriveLetter = partition.DriveLetter,
                                FileSystem = partition.FileSystem,
                                FreeSpace = partition.FreeSpace,
                                UsedSpace = partition.UsedSpace,
                                Description = partition.Description,
                                VolumeName = partition.VolumeName,
                            }).ToList(),
                        };
                        result.Add(model);
                    }
                    return Ok(result);
                }
                return NotFound();
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for GetEA_DiskDetails for user: " + userid);
                return BadRequest(ex.ToString());
            }

        }

        [HttpGet]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [Route("{userid}/{orgid}")]
        public async Task<IActionResult> GetNotifications(string userid, string orgid)
        {
            try
            {
                logger.LogInformation("\nGET request triggered for GetResourceUtil\n");

                if (orgid != null)
                {
                    var notifications = await db.Notifications.Where(u => u.OrgID == orgid).ToListAsync();
                    if (notifications == null || notifications.Count() == 0)
                    {
                        return NotFound();
                    }
                    List<ITAMEANotificationDTO> result = new List<ITAMEANotificationDTO>();
                    foreach (var notification in notifications)
                    {
                        if (notification.DevType == "CPU")
                        {
                            notification.DevType = "Desktop";
                        }
                        var model = new ITAMEANotificationDTO()
                        {
                            CreatedAt = notification.CreatedAt,
                            Body = notification.Body ?? "-",
                            Header = notification.Header ?? "-",
                            IsRead = notification.IsRead,
                            Message = notification.Message ?? "-",
                            User = notification.User ?? "-",
                            AssetID = notification.AssetID,
                            OrgID = notification.OrgID,
                            DevType = notification.DevType,
                            Id = notification.Id
                        };
                        result.Add(model);
                    }
                    return Ok(result);
                }
                return NotFound();
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for GetResourceUtil for user: " + userid);
                return BadRequest(ex.ToString());
            }

        }

        [HttpGet]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [Route("{userid}/{orgid}/{id}")]
        public async Task<IActionResult> IsReadNotification(string userid, string orgid, int Id)
        {
            try
            {
                logger.LogInformation("\nGET request triggered for GetResourceUtil\n");
                
                if (orgid != null)
                {
                    Notification? notification = await db.Notifications.FirstOrDefaultAsync(n => n.Id == Id && n.OrgID == orgid);
                    if (notification == null)
                    {
                        return NotFound();
                    }
                    notification.IsRead = true;
                    await db.SaveChangesAsync();
                    return Ok();
                }
                return NotFound();
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for IsReadNotification for user: " + userid);
                return BadRequest(ex.ToString());
            }

        }

        [HttpGet]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [Route("{userid}/{orgid}")]
        public async Task<IActionResult> MarkAllAsRead(string userid, string orgid)
        {
            try
            {
                logger.LogInformation("\nGET request triggered for GetResourceUtil\n");

                if (orgid != null)
                {
                    List<Notification>? notifications = await db.Notifications.Where(n => n.OrgID == orgid).ToListAsync();
                    if (notifications == null)
                    {
                        return NotFound();
                    }
                    foreach (var notification in notifications)
                    {
                        notification.IsRead = true;
                    }
                    await db.SaveChangesAsync();
                    return Ok();
                }
                return NotFound();
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for IsReadNotification for user: " + userid);
                return BadRequest(ex.ToString());
            }
        }

        [HttpDelete]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [Route("{userid}/{orgid}/{id}")]
        public async Task<IActionResult> DeleteNotification(string userid, string orgid, int Id)
        {
            try
            {
                logger.LogInformation("\nGET request triggered for GetResourceUtil\n");

                if (orgid != null)
                {
                    Notification? notification = await db.Notifications.FirstOrDefaultAsync(n => n.Id == Id && n.OrgID == orgid);
                    if (notification == null)
                    {
                        return NotFound();
                    }
                    db.Remove(notification);
                    await db.SaveChangesAsync();
                    return Ok($"Deleted");
                }
                return NotFound();
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for IsReadNotification for user: " + userid);
                return BadRequest(ex.ToString());
            }

        }


        [HttpPost]
        public async Task<IActionResult> EA_AllSpecifications([FromBody] POST_ALL_DTO allValues)
        {
            if (allValues is null)
            {
                return BadRequest("Input Invalid");
            }
            if (string.IsNullOrEmpty(allValues.OrgID))
            {
                return BadRequest("Invalid Organization.");
            }
            if (db.Devices.FirstOrDefault(e => e.ObjectID.ToString() == allValues.ObjectID && e.OrgID.ToString() == allValues.OrgID) == null)
            {
                return BadRequest("Device does not exist in Devices list.");
            }
            if (db.Devices.FirstOrDefault(e => e.ObjectID.ToString() == allValues.ObjectID && e.OrgID.ToString() == allValues.OrgID).IsApproved == false)
            {
                return BadRequest("Device is not approved.");
            }
            string progress = "";
            string result = "";
            string globalAssetID = "";
            string globalOrgID = allValues.OrgID;

            /*-------------------------------------1. EA SPECIFICATIONS---------------------------------------*/
            try
            {
                EASpecificationDto? value1 = allValues.EASpecificationDTO;
                if (value1 == null)
                {
                    progress += "EASpecification is null.";
                }
                else
                {
                    try
                    {
                        logger.LogInformation("\n======================================================================\n" +
                        "POST request triggered for GetEADetails" +
                        "\n======================================================================\n");

                        if (value1 is null)
                        {
                            logger.LogInformation("Bad Request");
                            progress += "EASpecification is null.";
                        }
                        else
                        {
                            
                            //EndAgent Database
                            var existingModel = db.EASpecifications.FirstOrDefault(e => e.ObjectID == allValues.ObjectID && e.OrgID == value1.OrgID);

                            if (existingModel != null)
                            {
                                existingModel.SystemStatus = value1.SystemStatus;
                                existingModel.OperatingSystem = value1.OperatingSystem;
                                existingModel.LoginUser = value1.LoginUser;
                                existingModel.LastActive = value1.LastActive;
                                existingModel.Domain = value1.Domain;
                                existingModel.Privileges = value1.Privileges;
                                existingModel.NetworkAdapter = value1.NetworkAdapter;
                                existingModel.IPv4Address = value1.IPv4Address;
                                existingModel.IPv6Address = value1.IPv6Address;
                                existingModel.Gateway = value1.Gateway;
                                existingModel.SubnetMask = value1.SubnetMask;
                                existingModel.CreatedAt = DateTime.Now;
                                existingModel.AssetID = value1.AssetID;
                                existingModel.OrgID = value1.OrgID;
                                existingModel.ObjectID = allValues.ObjectID;

                                db.EASpecifications.Update(existingModel);
                            }
                            else
                            {
                                EASpecification newModel = new EASpecification
                                {
                                    SystemName = value1.SystemName,
                                    SystemStatus = value1.SystemStatus,
                                    OperatingSystem = value1.OperatingSystem,
                                    LoginUser = value1.LoginUser,
                                    LastActive = value1.LastActive,
                                    Domain = value1.Domain,
                                    Privileges = value1.Privileges,
                                    NetworkAdapter = value1.NetworkAdapter,
                                    IPv4Address = value1.IPv4Address,
                                    IPv6Address = value1.IPv6Address,
                                    Gateway = value1.Gateway,
                                    SubnetMask = value1.SubnetMask,
                                    AssetID = value1.AssetID,
                                    OrgID = value1.OrgID,
                                    ObjectID = allValues.ObjectID,
                                    CreatedAt = DateTime.Now
                                };

                                db.EASpecifications.Add(newModel);
                            }
                            db.SaveChanges();
                            result += "1";
                        }
                    }
                    catch (Exception ex)
                    {
                        logger.LogInformation("Code Error for EADetails");
                        progress += $"\n Error: {ex}";

                    }
                }
                
            }
            catch (Exception ex)
            {
               logger.LogInformation("Code Error for EADetails: " + ex.ToString() );
                progress += $"\n Error: {ex}";

            }

            /*-------------------------------------2. INSTALLED APPS---------------------------------------*/
            try
            {
                logger.LogInformation("\n======================================================================\n" +
                "POST request triggered for EAInstalledApps" +
                "\n======================================================================\n");
                List<InstalledAppDto> value2 = allValues.InstalledApps;

                if (value2 is null)
                {
                    logger.LogInformation("Bad Request");
                    progress += $"\n Error Installed Apps  : Bad Request";

                }
                else
                {
                    // To update Installed Apps instead of Inserting
                    foreach (var app in value2)
                    {
                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == app.OrgId);
                        globalAssetID = id.AssetID;
                        if (id is null)
                        {
                            progress += $"\n Error Installed Apps  : id not found";

                            logger.LogInformation("id not found");
                        }
                        else
                        {
                            await db.Database.ExecuteSqlRawAsync($"DELETE FROM Apps WHERE SystemId = {id.ID}");
                            break;
                        }
                        
                    }


                    foreach (var app in value2)
                    {
                        var id = db.EASpecifications.FirstOrDefault(e => e.ObjectID == allValues.ObjectID && e.OrgID == app.OrgId);
                        if (id != null)
                        {

                            InstalledApp model = new()
                            {
                                SystemId = id.ID,
                                AppName = app.AppName,
                                Provider = app.Provider,
                                InstalledOn = app.InstalledOn,
                                Size = app.Size,
                                Version = app.Version,
                                CreatedAt = DateTime.Now
                            };
                            await db.Apps.AddAsync(model);
                        }
                    }
                    db.SaveChanges();
                    result += "2";


                }

            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for EAInstalledApps");
                progress += $"\n Error: {ex}";

            }

            /*-------------------------------------3. INSTALLED UPDATES---------------------------------------*/
            try
            {
                logger.LogInformation("\n======================================================================\n" +
                " GET request triggered for EAUpdate" +
                "\n======================================================================\n");
                List<UpdateDto> value3 = allValues.Updates;
                if (value3 is null)
                {
                    logger.LogInformation("Bad Request");
                    progress += $"\n Error Installed Updates : Bad Request";

                }
                else
                {

                    foreach (var update in value3)
                    {
                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == update.OrgId);
                        if (id == null)
                        {
                            progress += $"\n Error Installed Updates : id is null";

                        }
                        else
                        {
                            var query = from u in db.Updates
                                        where u.Title == update.Title && u.SystemId == id.ID
                                        select u;
                            var temp = await query.FirstOrDefaultAsync();

                            if (temp is null)
                            {
                                Update model = new()
                                {
                                    SystemId = id.ID,
                                    Title = update.Title,
                                    Patch = update.Patch,
                                    Description = update.Description,
                                    InstalledOn = update.InstalledOn,
                                    Version = update.Version,
                                    CreatedOn = DateTime.Now
                                };
                                await db.Updates.AddAsync(model);
                            }
                        }
                    }
                    await db.SaveChangesAsync();
                    result += "3";
                }
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error in EAUpdate");
                progress += "error Installed Updates : " + ex.ToString();
            }

            /*-------------------------------------4. PORT DETAILS---------------------------------------*/
            try
            {
                logger.LogInformation("\n======================================================================\n" +
                "POST request triggered for PortDetails" +
                "\n======================================================================\n");
                List<PortDto> value4 = allValues.Ports;

                if (value4 is null)
                {
                    logger.LogInformation("Bad Request");
                    progress += $"\n Error Port Details : Bad Request";


                }
                else
                {
                    // To update Installed Apps instead of Inserting
                    foreach (var app in value4)
                    {
                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == app.OrgId);
                        if (id is null)
                        {
                            progress += $"\n Error Port Details : id is null";

                        }
                        else
                        {
                            var portsToDelete = db.Ports.Where(a => a.SystemId == id.ID);
                            await db.Database.ExecuteSqlRawAsync($"DELETE FROM Ports WHERE SystemId = {id.ID}");
                            break;
                        }
                    }


                    foreach (var port in value4)
                    {
                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == port.OrgId);
                        if (id != null)
                        {

                            Port model = new()
                            {
                                SystemId = id.ID,
                                PortNumber = port.PortNumber,
                                ProcessId = port.ProcessId,
                                ProcessName = port.ProcessName,
                                CreatedAt = DateTime.Now
                            };
                            await db.Ports.AddAsync(model);
                        }
                    }
                    //db.Database.ExecuteSqlRaw($"DBCC CHECKIDENT('Ports', RESEED)");
                    await db.SaveChangesAsync();

                    result += "4";
                    logger.LogInformation("SUCCESS");
                }
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for PortDetails");
                progress += $"\n Error: {ex}";

            }

            /*-------------------------------------5. Location---------------------------------------*/
            try
            {
                var value5 = allValues.LocationDTO;
                logger.LogInformation("EAGeoLocation Post request generated.");
                if (value5 is null || value5.Longitude == "-" || value5.Latitude == "-")
                {
                    progress += $"\n The received coordinates were null or invalid.";

                }
                else
                {
                    var asset = await db.EASpecifications.FirstOrDefaultAsync(a => a.ObjectID == allValues.ObjectID && a.OrgID == value5.OrgId);
                    if (asset == null)
                    {
                        progress += $"\n There is no asset with the system name";

                    }
                    else
                    {
                        int assetId = asset.ID;
                        var existingModel = db.Locations.FirstOrDefault(e => e.SystemId == assetId);
                        if (existingModel != null)
                        {
                            existingModel.Longitude = value5.Longitude;
                            existingModel.Latitude = value5.Latitude;
                            existingModel.CreatedAt = DateTime.Now;
                            db.Locations.Update(existingModel);
                            await db.SaveChangesAsync();
                            result += "5";
                        }
                        else
                        {
                            Location model = new Location()
                            {
                                Longitude = value5.Longitude,
                                Latitude = value5.Latitude,
                                SystemId = assetId,
                                CreatedAt = DateTime.Now
                            };
                            db.Locations.Add(model);
                            await db.SaveChangesAsync();
                            result += "5";

                        }
                    }
                }
            }
            catch (Exception ex)
            {
                logger.LogInformation("EAGeoLocation Post request error. " + ex.ToString());
                progress += $"\n Error: {ex}";

            }

            /*-------------------------------------6. SERVICE DETAILS---------------------------------------*/
            try
            {
                logger.LogInformation("\n======================================================================\n" +
                "POST request triggered for ServiceDetails" +
                "\n======================================================================\n");
                var value6 = allValues.Services;
                if (value6 is null)
                {
                    logger.LogInformation("Bad Request");
                    progress += $"\n Error service details: Bad request";


                }
                else
                {
                    // To update Installed Apps instead of Inserting
                    foreach (var service in value6)
                    {
                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == service.OrgId);
                        if (id is null)
                        {
                            progress += $"\n Error service details: id not found";

                        }
                        else
                        {
                            var portsToDelete = db.Ports.Where(a => a.SystemId == id.ID);
                            await db.Database.ExecuteSqlRawAsync($"DELETE FROM Services WHERE SystemId = {id.ID}");
                            break;
                        }
                    }


                    foreach (var service in value6)
                    {
                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == service.OrgId);
                        if (id != null)
                        {

                            Service model = new()
                            {
                                SystemId = id.ID,
                                ServiceName = service.ServiceName,
                                DisplayName = service.DisplayName,
                                ServiceStatus = service.ServiceStatus,
                                ServiceType = service.ServiceType,
                                StartType = service.StartType,
                                PID = service.PID,
                                CreatedAt = DateTime.Now
                            };
                            await db.Services.AddAsync(model);
                        }
                    }
                    //db.Database.ExecuteSqlRaw($"DBCC CHECKIDENT('Ports', RESEED)");
                    await db.SaveChangesAsync();


                    logger.LogInformation("SUCCESS");
                    result += "6";
                }
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for ServiceDetails");
                progress += $"\n Error: {ex}";

            }

            /*-------------------------------------7. PROCESS DETAILS---------------------------------------*/
            try
            {
                logger.LogInformation("\n======================================================================\n" +
                "POST request triggered for ProcessDetails" +
                "\n======================================================================\n");
                var value7 = allValues.Processes;
                if (value7 is null)
                {
                    logger.LogInformation("Bad Request");
                    progress += $"\n Error process details: bad request";


                }
                else
                {
                    // To update Installed Apps instead of Inserting
                    foreach (var process in value7)
                    {
                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == process.OrgId);
                        if (id is null)
                        {
                            progress += $"\n Error processes details: id not found";

                        }
                        else
                        {
                            var portsToDelete = db.Processes.Where(a => a.SystemId == id.ID);
                            await db.Database.ExecuteSqlRawAsync($"DELETE FROM Processes WHERE SystemId = {id.ID}");
                            break;
                        }
                    }


                    foreach (var process in value7)
                    {
                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == process.OrgId);
                        if (id != null)
                        {

                            Process model = new()
                            {
                                SystemId = id.ID,
                                ProcessId = process.ProcessId,
                                ProcessName = process.ProcessName,
