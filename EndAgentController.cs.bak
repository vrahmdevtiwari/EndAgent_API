            catch (Exception ex)
            {
                logger.LogInformation("Code Error for ActiveNetworkDetails");
                progress += $"\n Error ActiveNetworkDetails details: {ex}";

            }

            /*-------------------------------------20. RESOURCE UTILIZATION DETAILS---------------------------------------*/
            try
            {
                logger.LogInformation("\n======================================================================\n" +
                "POST request triggered for Resource Utilization" +
                "\n======================================================================\n");
                var value20 = allValues.ResourceUtils;
                if (value20 is null)
                {
                    logger.LogInformation("Bad Request");
                    progress += $"\n Error Resource Utilization: Bad Request";


                }
                // To update Installed Apps instead of Inserting
                else
                {
                    var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == value20.OrgId);
                    if (id is null)
                    {
                        progress += $"\n Error Resource Utilization: id not found";

                    }
                    else
                    {
                        var toDelete = db.ResourceUtils.Where(a => a.SystemId == id.ID);
                        await db.Database.ExecuteSqlRawAsync($"DELETE FROM ResourceUtils WHERE SystemId = {id.ID}");

                        ResourceUtil model = new()
                        {
                            SystemId = id.ID,
                            BytesSent = value20.BytesSent,
                            BytesReceived = value20.BytesReceived,
                            CPUUsage = value20.CPUUsage,
                            MemoryUsage = value20.MemoryUsage,
                            PhysicalDiskUsage = value20.PhysicalDiskUsage,
                            GPUUsage = value20.GPUUsage,
                            CreatedAt = DateTime.Now
                        };
                        await db.ResourceUtils.AddAsync(model);

                        //db.Database.ExecuteSqlRaw($"DBCC CHECKIDENT('Ports', RESEED)");
                        await db.SaveChangesAsync();


                        logger.LogInformation("SUCCESS");
                        result += "20";
                    }
                }
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for EAOtherSpecifications");
                progress += $"\n Error Other Specifcations tasks details: {ex}";

            }

            /*-------------------------------------21. DiskDetails---------------------------------------*/
            try
            {
                logger.LogInformation("\n======================================================================\n" +
                "POST request triggered for Disk Details" +
                "\n======================================================================\n");
                var value21 = allValues.DiskDetails;
                if (value21 is null)
                {
                    logger.LogInformation("Bad Request");
                    progress += $"\n Error Disk Details: Bad Request";


                }
                else
                {
                    // Notifications
                    var ea = db.EASpecifications.FirstOrDefault(e => e.ObjectID == allValues.ObjectID && e.OrgID == globalOrgID);
                    var deviceId = db.Devices.FirstOrDefault(d => d.ObjectID.ToString() == allValues.ObjectID && d.OrgID.ToString() == globalOrgID).Id.ToString();
                    string devicetype = "Workstation";
                    if (db.DiskDetails.FirstOrDefault(r => r.SystemId == ea.ID) != null)
                    {
                        var oldDetails = await db.DiskDetails
                                        .Where(r => r.SystemId == ea.ID)
                                        .Select(r => new DiskDetailDTO
                                        {
                                            Id = r.Id,
                                            AssetId = r.EASpecification.AssetID,
                                            OrgId = r.EASpecification.OrgID,
                                            Partitions = r.Partitions,
                                            DeviceID = r.DeviceID,
                                            Capacity = r.Capacity,
                                            FirmwareRevision = r.FirmwareRevision,
                                            Index = r.Index,
                                            InstallDate = r.InstallDate,
                                            InterfaceType = r.InterfaceType,
                                            Manufacturer = r.Manufacturer,
                                            MediaType = r.MediaType,
                                            Model = r.Model,
                                            SerialNumber = r.SerialNumber,
                                            Status = r.Status
                                        })
                                        .ToListAsync();
                        AddNotification _notificationService = new AddNotification();
                        List<Notification> notifications = _notificationService.GenerateDiskChangeNotification(oldDetails, value21, ea.AssetID, ea.OrgID, devicetype, deviceId);
                        if (notifications != null)
                        {
                            foreach (Notification notification in notifications)
                            {
                                if (notification != null)
                                {
                                    await db.AddAsync(notification);
                                    await db.SaveChangesAsync();
                                }
                            }
                        }
                    }
                    // End Notifications

                    // To update Installed Apps instead of Inserting
                    foreach (var x in value21)
                    {
                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == x.OrgId);
                        if (id is null)
                        {
                            progress += $"\n Error Disk Details: id not found";

                        }
                        else
                        {
                            var toDelete = db.DiskDetails.Where(a => a.SystemId == id.ID);
                            await db.Database.ExecuteSqlRawAsync($"DELETE FROM DiskDetails WHERE SystemId = {id.ID}");
                            break;
                        }
                    }




                    foreach (var x in value21)
                    {
                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID== allValues.ObjectID && e.OrgID == x.OrgId);
                        if (id != null)
                        {
                            DiskDetail model = new()
                            {
                                SystemId = id.ID,
                                Capacity = x.Capacity,
                                DeviceID = x.DeviceID,
                                FirmwareRevision = x.FirmwareRevision,
                                Index = x.Index,
                                InstallDate = x.InstallDate,
                                InterfaceType = x.InterfaceType,
                                Manufacturer = x.Manufacturer,
                                Model = x.Model,
                                MediaType = x.MediaType,
                                Partitions = x.Partitions,
                                SerialNumber = x.SerialNumber,
                                Status = x.Status,
                                PartitionDetails = x.PartitionDetails.Select(partition => new PartitionDetail
                                {
                                    DeviceID = partition.DeviceID,
                                    Index = partition.Index,
                                    DiskIndex = partition.DiskIndex,
                                    Bootable = partition.Bootable,
                                    BootPartition = partition.BootPartition,
                                    PrimaryPartition = partition.PrimaryPartition,
                                    Size = partition.Size,
                                    State = partition.State,
                                    DriveLetter = partition.DriveLetter,
                                    FileSystem = partition.FileSystem,
                                    FreeSpace = partition.FreeSpace,
                                    UsedSpace = partition.UsedSpace,
                                    Description = partition.Description,
                                    VolumeName = partition.VolumeName,
                                }).ToList(),
                                CreatedAt = DateTime.Now
                            };
                            await db.DiskDetails.AddAsync(model);
                        }
                    }
                    //db.Database.ExecuteSqlRaw($"DBCC CHECKIDENT('Ports', RESEED)");
                    await db.SaveChangesAsync();


                    logger.LogInformation("SUCCESS");
                    result += "21";
                }
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for Disk Details");
                progress += $"\n Error Disk Details details: {ex}";

            }






            if (progress == "")
            {
                return Ok($"SUCCESS {result}");
            }
            return Ok(result + ": " + progress);

        }   

        


        [HttpGet]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [Route("{userid}/{orgid}")]
        public async Task<IActionResult> GetDevices(string userid, string orgid)
        {
            try
            {
                if (!string.IsNullOrEmpty(orgid))
                {
                    var devices = await db.Devices
                                    .Where(d => d.OrgID.ToString() == orgid)
                                    .Select(d => new ITAMEADeviceDTO
                                    {
                                        SystemName = d.SystemName,
                                        LoginUser = d.LoginUser,
                                        Domain = d.Domain,
                                        Privileges = d.Privileges,
                                        Manufacturer = d.Manufacturer,
                                        OS = d.OS,
                                        PublicIP = d.PublicIP,
                                        ID = d.Id,
                                        IsApproved = d.IsApproved,
                                        InITAM = d.InITAM
                                    })
                                    .ToListAsync();
                    if (devices == null) return NotFound();
                    return Ok(devices);
                }
                return BadRequest("Invalid Organization.");
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for IsReadNotification for user: " + userid);
                return BadRequest(ex.ToString());
            }
        }

        [HttpGet]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [Route("{userid}/{ID}")]
        public async Task<IActionResult> ApproveDevice (string userid, int ID)
        {
            var device = db.Devices.FirstOrDefault(d => d.Id == ID);
            if (device == null)
            {
                return NotFound();
            }
            else
            {
                device.IsApproved = true;
                await db.SaveChangesAsync();
                return Ok();
            }
        }

        [HttpDelete]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [Route("{userid}/{ID}")]
        public async Task<IActionResult> DeleteDevice(string userid, int ID)
        {
            var device = db.Devices.FirstOrDefault(d => d.Id == ID);
            if (device == null)
            {
                return NotFound();
            }
            else
            {
                db.Devices.Remove(device);
                await db.SaveChangesAsync();
                return Ok();
            }
        }

        [HttpPost]
        public async Task<IActionResult> AddDevice([FromBody] DeviceDTO value)
        {
            string action = "AddDevice";
            string subError = $"Error in {action}";
            if (value == null) 
            {
                logger.LogInformation($"{subError}: device is null.");
                return BadRequest($"{subError}: device is null.");
            }
            else
            {
                // Dev: Viraj; Date: 06-04-2024 {changes for BIOS_SN and OBJID Combination Check}
                Device? device = db.Devices.FirstOrDefault(d => d.ObjectID.ToString() == value.ObjectID);
                Device? device2 = db.Devices.FirstOrDefault(d => d.BIOS_SN == value.BIOS_SN);
                if (device != null || device2 != null)
                {
                    if (device != device2)
                    {
                        if (device2 != null)
                        {
                            Notification notification = new()
                            {
                                Header = "CRITICAL ALERT",
                                Body = $"\"{device2.SystemName}\" has been compromised as a new device is pretending to be the same.",
                                AssetID = device2.SystemName,
                                OrgID = device2.OrgID.ToString(),
                                CreatedAt = DateTime.Now,
                                DevType = "",
                                Message = "",
                                User = device2.Id.ToString(),
                                IsRead = false
                            };
                            db.Notifications.Add(notification);

                        }
                        else if (device != null)
                        {
                            Notification notification = new()
                            {
                                Header = "CRITICAL ALERT",
                                Body = $"\"{device.SystemName}\" has been compromised as a new device is pretending to be the same.",
                                AssetID = device.SystemName,
                                OrgID = device.OrgID.ToString(),
                                CreatedAt = DateTime.Now,
                                DevType = "",
                                Message = "",
                                User = device.Id.ToString(),
                                IsRead = false
                            };
                            db.Notifications.Add(notification);

                        }
                        db.SaveChanges();
                        return BadRequest("Compromised Device");
                    }
                }
                if (device != null)
                {
                    
                    
                    Device model = new()
                    {
                        SystemName = value.SystemName,
                        Domain = value.Domain,
                        LastSyncedTime = DateTime.Now.ToString(),
                        LoginUser = value.LoginUser,
                        Manufacturer = value.Manufacturer,
                        OS = value.OS,
                        Privileges = value.Privileges,
                        PublicIP = value.PublicIP,
                    };
                    

                    db.SaveChanges();
                    if (device.IsApproved == false)
                    {
                        return Ok($"Device {value.SystemName} already exists. Waiting for approval.");
                    }

                    return Ok($"Approved");

                }
                else
                {

                    Device model = new()
                    {
                        SystemName = value.SystemName,
                        Domain = value.Domain,
                        LastSyncedTime = DateTime.Now.ToString(),
                        LoginUser = value.LoginUser,
                        Manufacturer = value.Manufacturer,
                        OrgID = value.OrgID,
                        OS = value.OS,
                        Privileges = value.Privileges,
                        PublicIP = value.PublicIP,
                        CreatedAt = DateTime.Now,
                        BIOS_SN = value.BIOS_SN
                    };


                    // If in ITAM CheckITAMds (laptop,cpu,mobiled,server,none)
                    Validations validations = new Validations();
                    string dtypeurl = $"{baseUrl}{deviceTypeEndPoint}/{value.OrgID}/{value.SystemName}";
                    var d = await validations.GetDataInOneString(dtypeurl, itamApiKeyHeader, itamApiKey);
                    if (d.Contains("*error*"))
                    {
                        logger.LogInformation($"\n Error EASpecifications: " + d.ToString());

                    }
                    else if(d == "none")
                    {
                        // nothing as InITAM false by default.
                    }
                    else
                    {
                        model.InITAM = true;
                    }

                    db.Devices.Add(model);
                    db.SaveChanges();

                    return Ok($"{model.ObjectID}");
                }
            }
        }


        // Dev: Viraj Date: 09-05-2024
        [HttpGet]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [Route("{userid}/{orgid}")]
        public async Task<IActionResult> GetDevicesForUpdate(string userid, string orgid)
        {
            try
            {
                if (!string.IsNullOrEmpty(orgid))
                {
                    var devices = await db.Devices
                                    .Where(d => d.IsApproved == true)
                                    .Select(d => new ITAMEADeviceDTO
                                    {
                                        SystemName = d.SystemName,
                                        LoginUser = d.LoginUser,
                                        Domain = d.Domain,
                                        Privileges = d.Privileges,
                                        Manufacturer = d.Manufacturer,
                                        OS = d.OS,
                                        PublicIP = d.PublicIP,
                                        ID = d.Id,
                                        IsApproved = d.IsApproved,
                                        InITAM = d.InITAM,
                                        OrgID = d.OrgID.ToString()
                                    })
                                    .ToListAsync();
                    if (devices == null) return NotFound();
                    return Ok(devices);
                }
                return BadRequest("Invalid Organization.");
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for IsReadNotification for user: " + userid);
                return BadRequest(ex.ToString());
            }
        }

        [HttpGet]
        [Route("{ID}")]
        public async Task<ActionResult> GetBIOS(string ID)
        {
            try
            {
                if (string.IsNullOrEmpty(ID))
                {
                    logger.LogInformation("ID is empty/null");
                    return BadRequest("ID is empty/null");
                }

                Device device = db.Devices.FirstOrDefault(d => d.Id.ToString().Trim() == ID.Trim());
                if (device == null)
                {
                    return NotFound();
                }

                BIOSDetailsDTO data = new BIOSDetailsDTO();
                data.BIOS = device.BIOS_SN;
                data.ID = device.ObjectID.ToString();
                return Ok(data);

            }
            catch (Exception ex)
            {
                logger.LogInformation(ex.ToString());
                return BadRequest(ex.ToString());
            }
        }
    }
}
