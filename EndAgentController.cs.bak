                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == x.OrgId);
                        if (id is null)
                        {
                            progress += $"\n Error Accounts details: id not found";

                        }
                        else
                        {
                            var toDelete = db.Accounts.Where(a => a.SystemId == id.ID);
                            await db.Database.ExecuteSqlRawAsync($"DELETE FROM Accounts WHERE SystemId = {id.ID}");
                            break;
                        }
                    }


                    foreach (var x in value17)
                    {
                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == x.OrgId);
                        if (id != null)
                        {
                            Account model = new()
                            {
                                SystemId = id.ID,
                                Name = x.Name,
                                AccountType = x.AccountType,
                                Caption = x.Caption,
                                Domain = x.Domain,
                                SID = x.SID,
                                CreatedAt = DateTime.Now
                            };
                            await db.Accounts.AddAsync(model);
                        }
                    }
                    //db.Database.ExecuteSqlRaw($"DBCC CHECKIDENT('Ports', RESEED)");
                    await db.SaveChangesAsync();


                    logger.LogInformation("SUCCESS");
                    result += "17";
                }
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for Accounts");
                progress += $"\n Error Accounts details: {ex}";

            }

            /*-------------------------------------18. ACTIVE PORTS---------------------------------------*/
            try
            {
                logger.LogInformation("\n======================================================================\n" +
                "POST request triggered for Active Ports" +
                "\n======================================================================\n");
                var value18 = allValues.ActivePorts;
                if (value18 is null)
                {
                    logger.LogInformation("Bad Request");
                    progress += $"\n Error Active Port details: Bad Request";


                }
                else
                {
                    // To update Installed Apps instead of Inserting
                    foreach (var x in value18)
                    {
                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == x.OrgId);
                        if (id is null)
                        {
                            progress += $"\n Error Active Port details: id not found";

                        }
                        else
                        {
                            var toDelete = db.ActivePorts.Where(a => a.SystemId == id.ID);
                            await db.Database.ExecuteSqlRawAsync($"DELETE FROM ActivePorts WHERE SystemId = {id.ID}");
                            break;
                        }
                    }




                    foreach (var x in value18)
                    {
                        


                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == x.OrgId);
                        if (id != null)
                        {
                            ActivePort model = new()
                            {
                                SystemId = id.ID,
                                PID = x.PID,
                                Proto = x.Proto,
                                ForeignAddress = x.ForeignAddress,  
                                LocalAddress = x.LocalAddress,
                                State = x.State,
                                CreatedAt = DateTime.Now
                            };
                            await db.ActivePorts.AddAsync(model);
                        }
                    }
                    //db.Database.ExecuteSqlRaw($"DBCC CHECKIDENT('Ports', RESEED)");
                    await db.SaveChangesAsync();


                    logger.LogInformation("SUCCESS");
                    result += "18";
                }
            }
            catch (Exception ex)
            {
                logger.LogInformation("Code Error for ActivePorts");
                progress += $"\n Error ActivePorts details: {ex}";

            }


            /*-------------------------------------19. ACTIVE NETWORK DETAILS ---------------------------------------*/
            try
            {
                logger.LogInformation("\n======================================================================\n" +
                "POST request triggered for ActiveNetworkDetails" +
                "\n======================================================================\n");
                var value19 = allValues.ActiveNetworkDetails;
                if (value19 is null)
                {
                    logger.LogInformation("Bad Request");
                    progress += $"\n Error Active Network Details: Bad Request";


                }
                else
                {
                    // To update Installed Apps instead of Inserting
                    foreach (var x in value19)
                    {
                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == x.OrgId);
                        if (id is null)
                        {
                            progress += $"\n Error Active Network Details: id not found";

                        }
                        else
                        {
                            var toDelete = db.ActiveNetworkDetails.Where(a => a.SystemId == id.ID);
                            await db.Database.ExecuteSqlRawAsync($"DELETE FROM ActiveNetworkDetails WHERE SystemId = {id.ID}");
                            break;
                        }
                    }




                    foreach (var x in value19)
                    {



                        var id = await db.EASpecifications.FirstOrDefaultAsync(e => e.ObjectID == allValues.ObjectID && e.OrgID == x.OrgId);
                        if (id != null)
                        {
                            ActiveNetworkDetail model = new()
                            {
                                SystemId = id.ID,
                                IpAddress = x.IpAddress,
                                MacAddress = x.MacAddress,
                                DefaultGateway = x.DefaultGateway,
                                Description = x.Description,
                                DhcpEnabled = x.DhcpEnabled,
                                DnsServers = x.DnsServers,
